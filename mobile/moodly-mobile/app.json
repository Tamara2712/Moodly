{
  "expo": {
    "name": "moodly-mobile",
    "slug": "moodly-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/LOGO1024x1024.png",
    "scheme": "moodlymobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.dantvi.moodly",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/LOGO1024x1024.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/LOGO1024x1024.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/LOGO1242x2436.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "9e6f09dd-25ce-4999-b04f-904b532147fc"
      }
    }
  }
}
